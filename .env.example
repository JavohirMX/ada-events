SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,your-domain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://your-domain.com

ENABLE_RATE_LIMITING=True
RSVP_RATE_LIMIT_COUNT=12
RSVP_RATE_LIMIT_WINDOW=60
EVENT_CREATE_RATE_LIMIT_COUNT=5
EVENT_CREATE_RATE_LIMIT_WINDOW=86400

ATTACHMENT_MAX_SIZE_MB=10
ATTACHMENT_MAX_COUNT=5
ATTACHMENT_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,doc,docx

SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
X_FRAME_OPTIONS=DENY
SECURE_REFERRER_POLICY=same-origin

POSTGRES_DB=ada_events
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Google OAuth Credentials
GOOGLE_OAUTH_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_OAUTH_SECRET=your-client-secret-here
